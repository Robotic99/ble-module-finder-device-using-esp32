                    Spacer(modifier = Modifier.padding(top = 8.dp))
                    CardLabel("ESP32 STATUS")
                    Text(status, color = TextPrimary, fontSize = 12.sp)
                    Spacer(modifier = Modifier.padding(top = 6.dp))
                    CardLabel("LOG")
                    Text(log, color = TextMuted, fontSize = 11.sp)
                }


                SectionLabel("SETUP")
                TwoButtonRow("Permissions", "Start Scan",  onAskPermissions, onStartScan,  secondary = true, primary = true)
                TwoButtonRow("Stop Scan",   "Connect",     onStopScan,       onConnect,    secondary = true, primary = true)
                TwoButtonRow("Disconnect",  "Ping",        onDisconnect,     onPing,       secondary = true, secondary2 = true)


                SectionLabel("ALERTS")
                TwoButtonRow("Ring",     "Dist Ring", onRing,     onDistanceRing, primary = true,  primary2 = true)
                TwoButtonRow("Light On", "Light Off", onLightOn,  onLightOff,     amber = true,    secondary = true)

                Row(modifier = Modifier.fillMaxWidth()) {
                    DangerButton("⬛  SILENCE ALL", onSilence, modifier = Modifier.fillMaxWidth())
                }


                SectionLabel("SIGNAL FILTER")
                Row(modifier = Modifier.fillMaxWidth()) {
                    StyledButton(
                        label = "Toggle  •  $filterLabel",
                        onClick = onToggleKalman,
                        modifier = Modifier.fillMaxWidth(),
                        secondary = true
                    )
                }


                SectionLabel("CUSTOM TONES")
                TwoButtonRow("Tone 1", "Tone 2", onTone1, onTone2, secondary = true, secondary2 = true)
                TwoButtonRow("Tone 3", "Tone Off", onTone3, onToneOff, secondary = true, secondary2 = true)
            }
        }
    }
}


@Composable
fun InfoCard(content: @Composable () -> Unit) {
    Box(
        modifier = Modifier
            .fillMaxWidth()
            .clip(RoundedCornerShape(14.dp))
            .background(BgCard)
            .border(1.dp, BorderColor, RoundedCornerShape(14.dp))
            .padding(16.dp)
    ) {
        Column { content() }
    }
}

@Composable
fun CardLabel(text: String) {
    Text(
        text,
        color = TextMuted,
        fontSize = 9.sp,
        fontWeight = FontWeight.Bold,
        letterSpacing = 2.sp,
        modifier = Modifier.padding(bottom = 2.dp)
    )
}

@Composable
fun SectionLabel(text: String) {
    Text(
        text,
        color = TextMuted,
        fontSize = 9.sp,
        fontWeight = FontWeight.Bold,
        letterSpacing = 2.sp,
        modifier = Modifier.padding(top = 4.dp, bottom = 2.dp)
    )
}

@Composable
fun StyledButton(
    label: String,
    onClick: () -> Unit,
    modifier: Modifier = Modifier,
    primary: Boolean = false,
    secondary: Boolean = false,
    amber: Boolean = false,
    danger: Boolean = false
) {
    val bgColor = when {
        primary   -> AccentCyan.copy(alpha = 0.15f)
        amber     -> AccentAmber.copy(alpha = 0.15f)
        danger    -> AccentRed.copy(alpha = 0.15f)
        else      -> BgCardAlt
    }
    val borderCol = when {
        primary   -> AccentCyan.copy(alpha = 0.5f)
        amber     -> AccentAmber.copy(alpha = 0.5f)
        danger    -> AccentRed.copy(alpha = 0.5f)
        else      -> BorderColor
    }
    val textCol = when {
        primary   -> AccentCyan
        amber     -> AccentAmber
        danger    -> AccentRed
        else      -> TextPrimary
    }
    OutlinedButton(
        onClick = onClick,
        modifier = modifier,
        shape = RoundedCornerShape(10.dp),
        colors = ButtonDefaults.outlinedButtonColors(containerColor = bgColor),
        border = androidx.compose.foundation.BorderStroke(1.dp, borderCol)
    ) {
        Text(label, color = textCol, fontSize = 12.sp, fontWeight = FontWeight.SemiBold, textAlign = TextAlign.Center)
    }
}

@Composable
fun DangerButton(label: String, onClick: () -> Unit, modifier: Modifier = Modifier) {
    StyledButton(label = label, onClick = onClick, modifier = modifier, danger = true)
}

@Composable
fun TwoButtonRow(
    leftLabel: String,
    rightLabel: String,
    onLeft: () -> Unit,
    onRight: () -> Unit,
    primary: Boolean  = false,
    primary2: Boolean = false,
    secondary: Boolean  = false,
    secondary2: Boolean = false,
    amber: Boolean    = false,
    amber2: Boolean   = false
) {
    Row(
        modifier = Modifier.fillMaxWidth(),
        horizontalArrangement = Arrangement.spacedBy(8.dp)
    ) {
        StyledButton(
            label = leftLabel,
            onClick = onLeft,
            modifier = Modifier.weight(1f),
            primary = primary,
            secondary = secondary,
            amber = amber
        )
        StyledButton(
            label = rightLabel,
            onClick = onRight,
            modifier = Modifier.weight(1f),
            primary = primary2,
            secondary = secondary2,
            amber = amber2
        )
    }
}
