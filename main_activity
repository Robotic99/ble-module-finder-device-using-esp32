class KalmanFilter(
    private var processNoise: Double = 0.1,
    private var measurementNoise: Double = 5.0
) {
    private var estimate: Double? = null
    private var errorCovariance: Double = 1.0

    fun filter(measurement: Double): Double {
        if (estimate == null) {
            estimate = measurement
            return measurement
        }

        errorCovariance += processNoise

        val gain = errorCovariance / (errorCovariance + measurementNoise)
        estimate = estimate!! + gain * (measurement - estimate!!)
        errorCovariance *= (1.0 - gain)
        return estimate!!
    }

    fun reset() {
        estimate = null
        errorCovariance = 1.0
    }
}


class MainActivity : ComponentActivity() {

    private val serviceUuid = UUID.fromString("12345678-1234-1234-1234-1234567890ab")
    private val controlUuid = UUID.fromString("12345678-1234-1234-1234-1234567890ac")
    private val statusUuid  = UUID.fromString("12345678-1234-1234-1234-1234567890ad")
    private val cccdUuid    = UUID.fromString("00002902-0000-1000-8000-00805f9b34fb")
    private val fallbackName = "Opti-Find"

    private var bluetoothAdapter: BluetoothAdapter? = null
    private var scanner: BluetoothLeScanner? = null
    private var bluetoothGatt: BluetoothGatt? = null
    private var controlCharacteristic: BluetoothGattCharacteristic? = null
    private var statusCharacteristic: BluetoothGattCharacteristic? = null
    private var foundDevice: BluetoothDevice? = null


    private val scanningText    = mutableStateOf("No")
    private val connectedText   = mutableStateOf("No")
    private val deviceNameText  = mutableStateOf("Not found")
    private val rawRssiText     = mutableStateOf("--")
    private val smoothedRssiText = mutableStateOf("--")
    private val bandText        = mutableStateOf("IDLE")
    private val trendText       = mutableStateOf("Press Start Scan")
    private val statusText      = mutableStateOf("--")
    private val distanceRingText = mutableStateOf("Off")
    private val logText         = mutableStateOf("App started")
    private val heatBar         = mutableStateOf(0f)


    private val useKalmanState   = mutableStateOf(false)
    private val filterLabelText  = mutableStateOf("Filter: EMA")
    private val activeToneText   = mutableStateOf("None")
    private val manualLedText    = mutableStateOf("Off")


    private var filteredRssi: Double? = null
    private var previousSmoothedRssi: Double? = null
    private var distanceRingEnabled = false
    private var lastAutoRangeSent: String? = null


    private val kalmanFilter = KalmanFilter()

    private val permissionLauncher = registerForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) { result ->
        val ok = result.values.all { it }
        logText.value = if (ok) "Permissions granted" else "Some permissions were denied"
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        val manager = getSystemService(BLUETOOTH_SERVICE) as BluetoothManager
        bluetoothAdapter = manager.adapter
        scanner = bluetoothAdapter?.bluetoothLeScanner

        setContent {
            AppScreen(
                scanning      = scanningText.value,
                connected     = connectedText.value,
                deviceName    = deviceNameText.value,
                rawRssi       = rawRssiText.value,
                smoothedRssi  = smoothedRssiText.value,
                band          = bandText.value,
                trend         = trendText.value,
                status        = statusText.value,
                distanceRing  = distanceRingText.value,
                heat          = heatBar.value,
                log           = logText.value,
                filterLabel   = filterLabelText.value,
                activeTone    = activeToneText.value,
                manualLed     = manualLedText.value,
                onAskPermissions = { askPermissions() },
                onStartScan   = { startScan() },
                onStopScan    = { stopScanNow() },
                onConnect     = { connectToFoundDevice() },
                onDisconnect  = { disconnectGatt() },
                onPing        = { sendCommand("PING") },
                onRing        = {
                    distanceRingEnabled = false
                    distanceRingText.value = "Off"
                    lastAutoRangeSent = null
                    sendCommand("ALERT=ON")
                },
                onDistanceRing = { startDistanceRing() },
                onSilence     = { silenceAll() },

                onToggleKalman = { toggleKalmanFilter() },
                onTone1       = { sendCustomTone(1) },
                onTone2       = { sendCustomTone(2) },
                onTone3       = { sendCustomTone(3) },
                onToneOff     = { sendCustomTone(0) },

                onLightOn     = { sendLightOnly(true) },
                onLightOff    = { sendLightOnly(false) }
            )
        }
    }

    override fun onDestroy() {
        stopScanNow()
        disconnectGatt()
        super.onDestroy()
    }

    private fun hasPermission(permission: String): Boolean {
        return ContextCompat.checkSelfPermission(this, permission) == PackageManager.PERMISSION_GRANTED
    }

    private fun requiredPermissions(): Array<String> {
        val needed = mutableListOf<String>()
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.S) {
            if (!hasPermission(Manifest.permission.BLUETOOTH_SCAN))
                needed.add(Manifest.permission.BLUETOOTH_SCAN)
            if (!hasPermission(Manifest.permission.BLUETOOTH_CONNECT))
                needed.add(Manifest.permission.BLUETOOTH_CONNECT)
        }
        if (!hasPermission(Manifest.permission.ACCESS_FINE_LOCATION))
            needed.add(Manifest.permission.ACCESS_FINE_LOCATION)
        return needed.toTypedArray()
    }

    private fun askPermissions() {
        val needed = requiredPermissions()
        if (needed.isEmpty()) logText.value = "Permissions already granted"
        else permissionLauncher.launch(needed)
    }

    @SuppressLint("MissingPermission")
    private fun startScan() {
        val needed = requiredPermissions()
        if (needed.isNotEmpty()) { logText.value = "Tap Ask Permissions first"; return }

        val s = scanner ?: run { logText.value = "Bluetooth scanner not available"; return }


        filteredRssi = null
        previousSmoothedRssi = null
        kalmanFilter.reset()

        rawRssiText.value      = "--"
        smoothedRssiText.value = "--"
        bandText.value         = "IDLE"
        trendText.value        = "Looking for Opti-Find..."
        heatBar.value          = 0f
        deviceNameText.value   = "Searching..."

        val filters = listOf(
            ScanFilter.Builder().setServiceUuid(ParcelUuid(serviceUuid)).build()
        )
        val settings = ScanSettings.Builder()
            .setScanMode(ScanSettings.SCAN_MODE_LOW_LATENCY)
            .build()

        s.stopScan(scanCallback)
        s.startScan(filters, settings, scanCallback)

        scanningText.value = "Yes"
        logText.value = "Scanning for Opti-Find..."
    }

    @SuppressLint("MissingPermission")
    private fun stopScanNow() {
        scanner?.stopScan(scanCallback)
        scanningText.value = "No"
        logText.value = "Scan stopped"
    }


    private fun smoothRssiEma(raw: Int): Double {
        val alpha = 0.25
        filteredRssi = if (filteredRssi == null) raw.toDouble()
        else alpha * raw + (1.0 - alpha) * filteredRssi!!
        return filteredRssi!!
    }


    private fun smoothRssi(raw: Int): Double {
        return if (useKalmanState.value) kalmanFilter.filter(raw.toDouble())
        else smoothRssiEma(raw)
    }


    private fun toggleKalmanFilter() {
        val newVal = !useKalmanState.value
        useKalmanState.value = newVal

        filteredRssi = null
        kalmanFilter.reset()
        filterLabelText.value = if (newVal) "Filter: Kalman" else "Filter: EMA"
        logText.value = if (newVal) "Switched to Kalman filter" else "Switched to EMA filter"
    }

    private fun bandFromRssi(rssi: Double): String {
        return when {
            rssi < -80 -> "FAR"
            rssi < -70 -> "MID"
            rssi < -60 -> "NEAR"
            else       -> "VERY_CLOSE"
        }
    }

    private fun trendFromRssi(current: Double): String {
        val previous = previousSmoothedRssi ?: return "Move around a little"
        val delta = current - previous
        return when {
            delta > 1.5  -> "Getting closer"
            delta < -1.5 -> "Getting farther"
            else         -> "About the same"
        }
    }

    private fun heatFromRssi(rssi: Double): Float {
        val minRssi = -95.0
        val maxRssi = -45.0
        val clamped = max(minRssi, min(maxRssi, rssi))
        return ((clamped - minRssi) / (maxRssi - minRssi)).toFloat()
    }

    private fun currentBandCommand(): String? {
        return when (bandText.value) {
            "FAR"        -> "RANGE=FAR"
            "MID"        -> "RANGE=MID"
            "NEAR"       -> "RANGE=NEAR"
            "VERY_CLOSE" -> "RANGE=VERY_CLOSE"
            else         -> null
        }
    }

    @SuppressLint("MissingPermission")
    private fun writeControl(cmd: String, showInLog: Boolean = true): Boolean {
        val needed = requiredPermissions()
        if (needed.isNotEmpty()) {
            if (showInLog) logText.value = "Tap Ask Permissions first"
            return false
        }
        val gatt = bluetoothGatt
        val characteristic = controlCharacteristic
        if (gatt == null || characteristic == null) {
            if (showInLog) logText.value = "Connect first"
            return false
        }
        characteristic.writeType = BluetoothGattCharacteristic.WRITE_TYPE_DEFAULT
        characteristic.value = cmd.toByteArray(Charset.forName("UTF-8"))
        val ok = gatt.writeCharacteristic(characteristic)
        if (showInLog) logText.value = if (ok) "Sent: $cmd" else "Failed to send: $cmd"
        return ok
    }

    private fun maybeSendDistanceRange() {
        if (!distanceRingEnabled) return
        if (connectedText.value != "Yes") return
        val cmd = currentBandCommand() ?: return
        if (cmd == lastAutoRangeSent) return
        val ok = writeControl(cmd, showInLog = false)
        if (ok) {
            lastAutoRangeSent = cmd
            logText.value = "Distance ring: ${cmd.removePrefix("RANGE=")}"
        }
    }

    private fun startDistanceRing() {
        if (connectedText.value != "Yes") { logText.value = "Connect first"; return }
        val cmd = currentBandCommand() ?: run {
            logText.value = "Start Scan first so the app knows near/far"
            return
        }
        distanceRingEnabled = true
        distanceRingText.value = "On"
        lastAutoRangeSent = null
        maybeSendDistanceRange()
    }

    private fun silenceAll() {
        distanceRingEnabled = false
        distanceRingText.value = "Off"
        lastAutoRangeSent = null
        activeToneText.value = "None"
        manualLedText.value  = "Off"
        if (connectedText.value == "Yes") {
            writeControl("RANGE=IDLE", showInLog = false)
            writeControl("ALERT=OFF", showInLog = true)
        } else {
            logText.value = "Distance ring off"
        }
    }


    private fun sendCustomTone(slot: Int) {
        if (connectedText.value != "Yes") { logText.value = "Connect first"; return }
        val cmd = if (slot == 0) "TONE=OFF" else "TONE=$slot"
        val ok = writeControl(cmd, showInLog = true)
        if (ok) {
            activeToneText.value = if (slot == 0) "None" else "Tone $slot"
        }
    }


    private fun sendLightOnly(on: Boolean) {
        if (connectedText.value != "Yes") { logText.value = "Connect first"; return }
        val cmd = if (on) "LED=ON" else "LED=OFF"
        val ok = writeControl(cmd, showInLog = true)
        if (ok) manualLedText.value = if (on) "On" else "Off"
    }

    private val scanCallback = object : ScanCallback() {
        @SuppressLint("MissingPermission")
        override fun onScanResult(callbackType: Int, result: ScanResult) {
            val device = result.device
            val advertisedName = result.scanRecord?.deviceName ?: device.name ?: fallbackName
            val raw     = result.rssi
            val smoothed = smoothRssi(raw)
            val trend   = trendFromRssi(smoothed)
            val band    = bandFromRssi(smoothed)
            val heat    = heatFromRssi(smoothed)

            foundDevice            = device
            deviceNameText.value   = advertisedName
            rawRssiText.value      = raw.toString()
            smoothedRssiText.value = String.format(Locale.US, "%.1f", smoothed)
            bandText.value         = band
            trendText.value        = trend
            heatBar.value          = heat

            previousSmoothedRssi = smoothed
            maybeSendDistanceRange()

            logText.value = if (distanceRingEnabled)
                "Live RSSI updated • auto ring active"
            else
                "Live RSSI updated"
        }

        override fun onScanFailed(errorCode: Int) {
            scanningText.value = "No"
            logText.value = "Scan failed: $errorCode"
        }
    }

    @SuppressLint("MissingPermission")
    private fun connectToFoundDevice() {
        val needed = requiredPermissions()
        if (needed.isNotEmpty()) { logText.value = "Tap Ask Permissions first"; return }
        val device = foundDevice ?: run { logText.value = "No device found yet. Start Scan first."; return }
        logText.value = "Connecting..."
        bluetoothGatt?.close()
        bluetoothGatt = device.connectGatt(this, false, gattCallback)
    }

    @SuppressLint("MissingPermission")
    private fun disconnectGatt() {
        bluetoothGatt?.disconnect()
        bluetoothGatt?.close()
        bluetoothGatt            = null
        controlCharacteristic    = null
        statusCharacteristic     = null
        connectedText.value      = "No"
        statusText.value         = "--"
        distanceRingEnabled      = false
        distanceRingText.value   = "Off"
        lastAutoRangeSent        = null
        activeToneText.value     = "None"
        manualLedText.value      = "Off"
        logText.value            = "Disconnected"
    }

    private val gattCallback = object : BluetoothGattCallback() {
        @SuppressLint("MissingPermission")
        override fun onConnectionStateChange(gatt: BluetoothGatt, status: Int, newState: Int) {
            runOnUiThread {
                if (newState == BluetoothProfile.STATE_CONNECTED) {
                    connectedText.value = "Yes"
                    logText.value = "Connected. Discovering services..."
                    gatt.discoverServices()
                } else if (newState == BluetoothProfile.STATE_DISCONNECTED) {
                    connectedText.value   = "No"
                    controlCharacteristic = null
                    statusCharacteristic  = null
                    statusText.value      = "--"
                    distanceRingEnabled   = false
                    distanceRingText.value = "Off"
                    lastAutoRangeSent     = null
                    activeToneText.value  = "None"
                    manualLedText.value   = "Off"
                    logText.value         = "GATT disconnected"
                }
            }
        }

        @SuppressLint("MissingPermission")
        override fun onServicesDiscovered(gatt: BluetoothGatt, status: Int) {
            runOnUiThread {
                val service = gatt.getService(serviceUuid) ?: run {
                    logText.value = "Service not found"; return@runOnUiThread
                }
                controlCharacteristic = service.getCharacteristic(controlUuid)
                statusCharacteristic  = service.getCharacteristic(statusUuid)
                if (statusCharacteristic != null)
                    enableStatusNotifications(gatt, statusCharacteristic!!)
                logText.value = if (controlCharacteristic != null)
                    "Ready to send commands"
                else
                    "Control characteristic not found"
            }
        }

        override fun onCharacteristicChanged(
            gatt: BluetoothGatt,
            characteristic: BluetoothGattCharacteristic
        ) {
            if (characteristic.uuid == statusUuid) {
                val value = characteristic.value?.toString(Charset.forName("UTF-8")) ?: ""
                runOnUiThread { statusText.value = value }
            }
        }
    }

    @SuppressLint("MissingPermission")
    private fun enableStatusNotifications(
        gatt: BluetoothGatt,
        characteristic: BluetoothGattCharacteristic
    ) {
        gatt.setCharacteristicNotification(characteristic, true)
        val descriptor = characteristic.getDescriptor(cccdUuid)
        if (descriptor != null) {
            descriptor.value = BluetoothGattDescriptor.ENABLE_NOTIFICATION_VALUE
            gatt.writeDescriptor(descriptor)
        }
    }

    private fun sendCommand(cmd: String) {
        writeControl(cmd, showInLog = true)
    }
}


